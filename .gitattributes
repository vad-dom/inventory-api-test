# Normalize all text files to LF
* text=auto eol=lf

# Shell scripts
*.sh       text eol=lf
*.bash     text eol=lf

# Environment files
*.env      text eol=lf
*.env.*    text eol=lf

# YAML
*.yml      text eol=lf
*.yaml     text eol=lf

# SQL scripts
*.sql      text eol=lf

# Docker
Dockerfile text eol=lf